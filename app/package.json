{
  "name": "deepcode-gui",
  "version": "0.1.0",
  "description": "DeepCode v3 desktop GUI",
  "main": "electron/main.js",
  "type": "module",
  "author": "DeepCode",
  "scripts": {
    "predev": "node scripts/freeport.mjs",
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "vite build && electron-builder"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0"
  },
  "build": {
    "appId": "com.deepcode.gui",
    "productName": "DeepCode",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../build/_pydist/bridge.exe",
        "to": "bridge/bridge.exe"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "DeepCodeGUI.exe"
    }
  }
}
